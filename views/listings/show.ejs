<% layout('/layouts/boilerplate.ejs') %>
<% if(error && error.length){ %>
<div class="alert alert-danger col-4 offset-4 mt-2">
    <%= error %>
</div>
<% } %>
<% if(success && success.length){ %>
<div class="alert alert-success col-4 offset-4 mt-2">
    <%= success %>
</div>
<% } %>
<div class="row-9 mt-3">
    <div class="col-8 offset-4">
    <h2><%= listing.title %></h2>
    <div class="card col-6 listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listingimg" >
                 <div class="card-body">
                       <p class="card-text"><p><%= listing.title %></p>
                       <p>Owned By : <i><%= listing.owner.username %></i></p>
                 </div>
    </div>
    <ul>
        <li><%= listing.description %></li>
         <li>&#8377 <%= listing.price ? listing.price.toLocaleString("en-IN"):"price not defined" %></li>
          <li><%= listing.location %></li>
           <li><%= listing.country%></li>
    </ul>
    <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
    <div class="show-btn">
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
          <button class="btn-delete">DELETE</button>
           </form>
            <form method="GET" action="/listings/<%= listing._id %>/edit">
             <button class="btn-edit">Edit</button>
               </form>
     </div>
     <% } %>
    
     <div class="col-8 ">
         <% if(currUser) { %>
        <h4>Leave a Review</h4>
        <form method="post" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-control">
            </div>
            <div class="mb-3 mt-3">
                <label for="comment"class="form-label" >Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
            </div>
            <button class="btn-review">Submit</button>
             <% } %>
        </form>
       
     </div>

          <h4> All Reviews</h4>
          <% for(review of listing.reviews) { %>
            <div class="card col-5 ms-3 mb-3" >
                <div class="card-body p-3">
                    <h5 class="card-title "><%= review.author.username %> </h5>
                    <p class="card-text "><%= review.comment %></p>
                    <p class="card-text  "><%= review.rating %>star</p>
                </div>
            </div>
          <%}%>

    </div>
</div>
